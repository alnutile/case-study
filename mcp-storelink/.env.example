# --- StoreLink target -------------------------------------------------------
# The mock in dev; the real StoreLink host inside Korral's network in prod.
STORELINK_BASE_URL=http://localhost:8000
STORELINK_TIMEOUT_MS=5000

# --- Transport --------------------------------------------------------------
# stdio: how Claude Desktop / Claude Code launch the server locally.
# http:  how it runs as a long-lived container inside Korral's GCP.
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080

# --- Audit log --------------------------------------------------------------
# SQLite file. Lives on a volume inside Korral's tenancy and never leaves it.
AUDIT_DB_PATH=./data/audit.db

# --- Secrets (choose ONE) ---------------------------------------------------
# PROD: a directory of per-store key files mounted from a secret manager.
#       filename = store_id, contents = that store's StoreLink key.
#       Re-read on rotation, no redeploy needed.
# KORRAL_KEYS_DIR=/var/run/secrets/korral
#
# DEV: inline JSON {"<store_id>":"<key>"} — never commit real keys.
KORRAL_KEYS={"47":"sk_live_47_a1b2c3d4","102":"sk_live_102_e5f6g7h8"}

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=info
